---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Jiachuan Zhu</h1>
			<p>Software engineer with backend and distributed systems background.</p>
			<p>
				Currently building mobile applications while exploring AI-assisted software development
				workflows.
			</p>
			<p>
				Interested in debugging, system behavior, and how large language models are changing
				engineering practice.
			</p>
		</main>
		<Footer />
	</body>
</html>
