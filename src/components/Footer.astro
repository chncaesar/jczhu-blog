---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span>© {today.getFullYear()} Jiachuan Zhu</span>
		<div class="links">
			<a href="https://github.com/chncaesar" target="_blank">github</a>
			<a href="https://dev.to/antonio_zhu_e726fd856cd86" target="_blank">dev.to</a>
			<a href="https://x.com/chncaesar165192" target="_blank">x</a>
			<a href="https://www.jianshu.com/u/212610e5b82b" target="_blank">jianshu</a>
			<a href="https://www.zhihu.com/people/zhu-jia-94-76" target="_blank">zhihu</a>
			<a href="/rss.xml">rss</a>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: 4em;
		padding: 1.5em;
		border-top: 1px solid var(--border);
	}
	.footer-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: 720px;
		margin: 0 auto;
		font-size: 0.8em;
		color: var(--fg-subtle);
	}
	.links {
		display: flex;
		gap: 1.25em;
	}
	.links a {
		color: var(--fg-subtle);
		text-decoration: none;
	}
	.links a:hover {
		color: var(--fg-muted);
	}
	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			gap: 0.5em;
			text-align: center;
		}
	}
</style>
